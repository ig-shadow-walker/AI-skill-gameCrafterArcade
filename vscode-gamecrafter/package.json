{
  "name": "gamecrafter",
  "displayName": "GameCrafter",
  "description": "Loads the GameCrafter Cursor skill into your project (.cursor/skills).",
  "version": "0.1.0",
  "publisher": "shadow-walker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shadow-walker/gameCrafter"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
